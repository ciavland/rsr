---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404">
  <h1>404 — nicht gefunden</h1>
  <p class="empty-state">
    Diese Seite existiert nicht. Anders als die Gebühr für den offiziellen
    Robidog-Sack, die existiert garantiert.
  </p>
  <a class="back-link" href={base}>← Zurück zu allen Rants</a>
</BaseLayout>
